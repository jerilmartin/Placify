# ── SUPABASE CONFIGURATION ────────────────────────────────────────────────────
# The URL of your Supabase project (found in Project Settings -> API)
SUPABASE_URL=https://your-project-id.supabase.co
# The Anon/Public Key of your Supabase project
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here
# The Service Role Key (secret key, do not share or publish)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key-here

# ── GEMINI AI CONFIGURATION ───────────────────────────────────────────────────
# Get your API key from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=AIzaSyYourGeminiApiKeyHere

# ── BACKEND AUTHENTICATION ────────────────────────────────────────────────────
# Secret key used to sign local JWT tokens if needed (random string)
JWT_SECRET=supersecretjwtstringchangeinproduction

# ── FRONTEND ENVIRONMENT VARIABLES ────────────────────────────────────────────
# Must match the Supabase URL above
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# Must match the Supabase Anon Key above
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here
# URL pointing to the FastAPI backend API
NEXT_PUBLIC_API_URL=http://localhost:8000
